# Servidor
PORT=3750
NODE_ENV=development
# List of URLs allowed for CORS, separated by commas (e.g., http://localhost:3000,https://app.governeai.com)
# Use * to allow all (not recommended in production)
CORS_ORIGINS=http://localhost:3000

# Banco de Dados
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_NAME=governeai
DATABASE_SSL=false

# JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua_chave_secreta_refresh_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Redis (opcional por enquanto)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek AI
DEEPSEEK_API_KEY=sua_api_key_deepseek
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_global_evolution_api
EVOLUTION_WEBHOOK_URL=https://seu-dominio.com/api/whatsapp/webhook

# Election Service
ELECTION_SERVICE_URL=http://localhost:3050

# Super Admin (seed inicial)
ADMIN_EMAIL=admin@governeai.com
ADMIN_PASSWORD=senha_admin_segura
ADMIN_NAME=Super Admin

# Lead Bot (API Key exclusiva do bot para /api/leads/bot)
LEAD_BOT_KEY=

# GoverneAI (API Key usada pela landing page em POST /api/leads e GET /api/plans)
GOVERNE_AI_API_KEY=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# URLs públicas (usadas em back_urls do MP, notification_url e no link do email)
API_URL=http://localhost:3859
LANDING_URL=http://localhost:3000
APP_URL=http://localhost:5173
SIGNUP_COMPLETION_PATH=/complete-signup

# Checkout
CHECKOUT_ADHESION_FEE=5000.00
SIGNUP_TOKEN_TTL_HOURS=72
CHECKOUT_TOKEN_PEPPER=

# Mail service externo
MAIL_SERVICE_URL=https://utils-mail-service.gkgtsp.easypanel.host/api/mail/send
MAIL_SERVICE_API_KEY=
MAIL_SENDER_EMAIL=
MAIL_SENDER_APP_PASSWORD=
MAIL_WHATSAPP_URL=
