# Servidor
PORT=3750
NODE_ENV=development

# Banco de Dados
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_NAME=governeai
DATABASE_SSL=false

# JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua_chave_secreta_refresh_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Redis (opcional por enquanto)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek AI
DEEPSEEK_API_KEY=sua_api_key_deepseek
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Super Admin (seed inicial)
ADMIN_EMAIL=admin@governeai.com
ADMIN_PASSWORD=senha_admin_segura
ADMIN_NAME=Super Admin
